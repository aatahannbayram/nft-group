# Neon Postgres — Project Settings > Connection string (use the "pooled connection" string)
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Uploaded gallery photos are stored on local disk (public/uploads) — no object storage needed

# Session signing secret — generate with: openssl rand -base64 32
SESSION_SECRET=""

# Single admin login (bcrypt hash, not the plain password). IMPORTANT: escape
# every "$" in the hash as "\$" — Next.js expands unescaped $VAR references in
# .env files and will silently mangle a bcrypt hash otherwise.
ADMIN_EMAIL="nftgroup.gim@gmail.com"
ADMIN_PASSWORD_HASH=""

# Resend — resend.com > API Keys
RESEND_API_KEY=""
