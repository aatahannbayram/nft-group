# Neon Postgres — Project Settings > Connection string (use the "pooled connection" string)
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Cloudflare R2 — R2 > Manage API Tokens > create S3-compatible API token
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="nft-group-gallery"
# R2 bucket public URL (either the r2.dev dev URL or a custom domain you connect to the bucket)
R2_PUBLIC_URL="https://pub-xxxxxxxx.r2.dev"

# Session signing secret — generate with: openssl rand -base64 32
SESSION_SECRET=""

# Single admin login (password hash generated by a setup script, not the plain password)
ADMIN_EMAIL="nftgroup.gim@gmail.com"
ADMIN_PASSWORD_HASH=""

# Resend — resend.com > API Keys
RESEND_API_KEY=""
